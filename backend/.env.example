# Copy to `.env` (do not commit `.env`). Required: MONGO_URI, JWT_SECRET, PORT.

PORT=5000
MONGO_URI=mongodb+srv://USER:PASSWORD@cluster.example.mongodb.net/mydb
JWT_SECRET=your_long_random_string
NODE_ENV=development

# Shop URL (where users land after clicking “verify” on the API)
FRONTEND_URL=http://localhost:5173

# API URL used inside verification emails (must reach this Node server)
# Local default is http://localhost:5000 — set to your public API URL in production.
API_PUBLIC_URL=http://localhost:5000

# -----------------------------------------------------------------------------
# Gmail + Nodemailer (required for signup verification mail in this project)
# Use a Google “App password”, not your normal Gmail password:
# https://support.google.com/accounts/answer/185833
# -----------------------------------------------------------------------------
EMAIL_USER=you@gmail.com
EMAIL_PASS=your-16-char-app-password

# Optional display name in the inbox “From” field
# APP_NAME=MINIS App

# -----------------------------------------------------------------------------
# Other email options (optional — used by other utilities if set)
# -----------------------------------------------------------------------------
# RESEND_API_KEY=re_xxxxxxxx
# RESEND_FROM=MINIS <noreply@yourdomain.com>
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_SECURE=false
# EMAIL_FROM=MINIS <you@gmail.com>

# -----------------------------------------------------------------------------
# SMS / phone OTP on sign-up — optional
# -----------------------------------------------------------------------------
# TWILIO_ACCOUNT_SID=ACxxxxxxxx
# TWILIO_AUTH_TOKEN=xxxxxxxx
# TWILIO_FROM_NUMBER=+15551234567
# DEFAULT_SMS_COUNTRY_CODE=92
# SMS_LOGIN_ALERT=true
